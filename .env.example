# ============================================================================
# Пример конфигурации. Скопируйте в .env и при необходимости отредактируйте:
#   cp .env.example .env
# Файл .env в репозиторий НЕ коммитится (см. .gitignore).
# ============================================================================

# ── PostgreSQL ──────────────────────────────────────────────────────────────
POSTGRES_USER=integration
POSTGRES_PASSWORD=integration
POSTGRES_DB=integration
POSTGRES_PORT=5432

# ── Kafka ────────────────────────────────────────────────────────────────────
# Порт брокера, проброшенный на хост (для kafka-console / внешних клиентов)
KAFKA_EXTERNAL_PORT=9092
# Фиксированный cluster id для KRaft (можно оставить как есть)
KAFKA_CLUSTER_ID=5L6g3nShT-eMCtK--X86sw
KAFKA_CONSUMER_GROUP=integration-consumer

# ── Источник данных 1С ─────────────────────────────────────────────────────
# mock  — воспроизводимый встроенный источник (демо/CI, без запущенной 1С)
# onec  — реальная 1С по HTTP-сервису
SOURCE_TYPE=mock

# Параметры реального HTTP-сервиса 1С (используются при SOURCE_TYPE=onec).
# Базовый URL публикации HTTP-сервиса 1С (путь /<wsdir>/hs/<rootURL>).
#
# ВАЖНО (сеть Docker → 1С на хосте Windows):
#   Сначала используйте host.docker.internal. Если конкретная конфигурация
#   Docker Desktop/IIS возвращает HTTP 502, укажите РЕАЛЬНЫЙ IPv4-адрес хоста
#   (адаптер vEthernet (WSL), смотреть `ipconfig`), например 172.23.128.1.
# Пример 1: ONEC_BASE_URL=http://host.docker.internal/roshim/hs/integration
# Пример: ONEC_BASE_URL=http://172.23.128.1/roshim/hs/integration
ONEC_BASE_URL=http://<HOST_IPV4>/roshim/hs/integration
ONEC_USERNAME=
ONEC_PASSWORD=
ONEC_TIMEOUT=30
# true или false; другие значения считаются ошибкой конфигурации.
ONEC_VERIFY_SSL=true
# Количество повторов должно быть >= 0; размер страницы — 1..5000.
ONEC_HTTP_RETRIES=3
ONEC_PAGE_SIZE=500
# Таймауты должны быть конечными числами > 0.
FK_BARRIER_TIMEOUT=30

# ── Consumer ───────────────────────────────────────────────────────────────
# MAX_RETRIES >= 0, BATCH_MAX_MESSAGES >= 1, BATCH_MAX_SECONDS > 0.
MAX_RETRIES=3
BATCH_MAX_MESSAGES=500
BATCH_MAX_SECONDS=2
CONSUMER_HEALTH_PORT=8081

# ── UI (опционально) ─────────────────────────────────────────────────────────
KAFKA_UI_PORT=8080
PGADMIN_PORT=5050
PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=admin

# ── Логирование ──────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
